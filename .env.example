# Copy this file to .env, fill in real values, then source it before running:
#   set -a; source .env; set +a
# in your shell or cron command before python3 main.py.
#
# .env itself is gitignored — never commit credentials.

# Yandex app password for IMAP login
# Generate at https://passport.yandex.ru/profile → app passwords
export IMAP_PASSWORD="your-yandex-app-password-for-imap"

# Yandex app password for SMTP (can be the same as IMAP_PASSWORD for most setups)
export SMTP_PASSWORD="your-yandex-app-password-for-smtp"

# Optional: healthchecks.io ping URL
# Get one at https://healthchecks.io/ (free tier)
# Reference in config.yaml as healthcheck_url
# export HEALTHCHECK_URL="https://hc-ping.com/your-uuid-here"
